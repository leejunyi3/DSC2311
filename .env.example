# ── AI assistant provider ───────────────────────────────────────────
# Which state-of-the-art LLM API powers the assistant: gemini | anthropic.
# Demo Mode + offline summaries work with NO key on either provider.
AI_PROVIDER=gemini

# ── Google Gemini (free tier, no credit card) ───────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# gemini-flash-lite-latest is the fast, reliable free-tier default.
# Or name a specific one, e.g. gemini-3-flash-preview / gemini-flash-latest.
GEMINI_MODEL=gemini-flash-lite-latest

# ── Anthropic Claude (alternative provider; needs a paid key) ───────
ANTHROPIC_API_KEY=
# No default is hardcoded in the app. If you use anthropic you MUST set this.
ANTHROPIC_MODEL=
ENABLE_ANTHROPIC_WEB_SEARCH=false

# ── AIS vessel data ─────────────────────────────────────────────────
# demo | aisstream
AIS_PROVIDER_MODE=demo
AISSTREAM_API_KEY=

# ── Live source toggles ─────────────────────────────────────────────
ENABLE_LIVE_WEATHER=true
ENABLE_LIVE_LIGHTNING=true
ENABLE_LIVE_MARINE=true
ENABLE_LIVE_DISRUPTIONS=false

# ── Cache + deterministic demo ──────────────────────────────────────
CACHE_TTL_SECONDS=300
DEMO_SCENARIO=pharmaceutical-crisis
DEMO_SEED=2301

# ── Optional external stores (unused in Demo Mode) ──────────────────
REDIS_URL=
DATABASE_URL=
